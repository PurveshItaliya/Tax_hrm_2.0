<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ══════════════════════════════════════════════════════════════════════
	     iOS 26 Liquid Glass design language opt-in.
	     Setting this to false allows UITabBar (and other system chrome) to
	     render the genuine Liquid Glass material on iOS 26+. Remove or set
	     to true to force the pre-iOS-26 flat appearance.
	     ══════════════════════════════════════════════════════════════════════ -->
	<key>UIDesignRequiresCompatibility</key>
	<false/>

	<!-- ═══════════════════════════════════════════════════════════════════
	     App Identity
	     ═══════════════════════════════════════════════════════════════════ -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>TAX HRM 2.0</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>tax_hrm</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.1</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>5</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- ═══════════════════════════════════════════════════════════════════
	     Privacy Usage Descriptions (NSUsageDescription)
	     All keys used by the app must be declared — App Store Review checks these.
	     ═══════════════════════════════════════════════════════════════════ -->

	<!-- Camera: required for selfie punch-in/out -->
	<key>NSCameraUsageDescription</key>
	<string>TAX HRM uses your camera to capture a photo for attendance verification during punch-in and punch-out.</string>

	<!-- Notifications: required for Punch In/Out reminders and work updates -->
	<key>NSUserNotificationUsageDescription</key>
	<string>TAX HRM uses notifications to send Punch In, Punch Out, attendance reminders, and important work updates.</string>


	<!-- Location (When In Use): required for selfie punch location check -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TAX HRM uses your location while the app is open to verify your work location during attendance punch-in and punch-out.</string>

	<!-- Location (Always + When In Use): required by permission_handler when requesting Always.
	     NOTE: iOS background location flow is currently inactive.
	     This key is kept to avoid App Store binary validation errors from the plugin. -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>TAX HRM uses your location in the background to automatically record attendance and track your work timeline during working hours.</string>

	<!-- Photo Library: required for document upload feature -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>TAX HRM needs access to your photo library to upload documents and profile images.</string>

	<!-- ═══════════════════════════════════════════════════════════════════
	     Background Modes
	     Only declare what the app actually uses.
	     NOTE: 'location' and 'processing' removed — iOS bg location is inactive.
	     ═══════════════════════════════════════════════════════════════════ -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
		<string>remote-notification</string>
	</array>

	<!-- ═══════════════════════════════════════════════════════════════════
	     UI Configuration
	     ═══════════════════════════════════════════════════════════════════ -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>FlutterSceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<!-- Portrait only for iPhone — matches SystemChrome.setPreferredOrientations in main.dart -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!-- iPad MUST include all 4 orientations for Apple multitasking compliance -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
